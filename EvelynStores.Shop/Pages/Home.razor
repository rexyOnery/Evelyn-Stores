<div class="modal fade modal-default" id="print-receipt" aria-labelledby="print-receipt">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-body">
                @if (CompletedSale != null)
                {
                    <div class="icon-head text-center">
                        <a href="javascript:void(0);">
                            <img src="assets/img/logo.svg" width="100" height="30" alt="Receipt Logo">
                        </a>
                    </div>
                    <div class="text-center info text-center">
                        <h6>EvePhil Stores Ltd.</h6>
                        <p class="mb-0">Phone Number: +234 XXX XXX XXXX</p>
                        <p class="mb-0">Email: <a href="mailto:info@evephilstores.com">info@evephilstores.com</a></p>
                    </div>
                    <div class="tax-invoice">
                        <h6 class="text-center">Sales Receipt</h6>
                        <div class="row">
                            <div class="col-sm-12 col-md-6">
                                <div class="invoice-user-name"><span>Transaction ID: </span>@CompletedSale.TransactionId</div>
                            </div>
                            <div class="col-sm-12 col-md-6">
                                <div class="invoice-user-name"><span>Date: </span>@CompletedSale.CreatedAt.ToString("dd MMM yyyy HH:mm")</div>
                            </div>
                        </div>
                    </div>
                    <table class="table-borderless w-100 table-fit">
                        <thead>
                            <tr>
                                <th># Item</th>
                                <th>Price</th>
                                <th>Qty</th>
                                <th class="text-end">Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (int i = 0; i < CompletedSale.Items.Count; i++)
                            {
                                var item = CompletedSale.Items[i];
                                <tr>
                                    <td>@(i + 1). @item.ProductName</td>
                                    <td>₦@item.UnitPrice.ToString("N2")</td>
                                    <td>@item.Quantity</td>
                                    <td class="text-end">₦@item.LineTotal.ToString("N2")</td>
                                </tr>
                            }
                            <tr>
                                <td colspan="4">
                                    <table class="table-borderless w-100 table-fit">
                                        <tr>
                                            <td class="fw-bold">Sub Total :</td>
                                            <td class="text-end">₦@CompletedSale.Subtotal.ToString("N2")</td>
                                        </tr>
                                        @if (CompletedSale.DiscountAmount > 0)
                                        {
                                            <tr>
                                                <td class="fw-bold text-danger">Discount :</td>
                                                <td class="text-end text-danger">-₦@CompletedSale.DiscountAmount.ToString("N2")</td>
                                            </tr>
                                        }
                                        @if (CompletedSale.ShippingAmount > 0)
                                        {
                                            <tr>
                                                <td class="fw-bold">Shipping :</td>
                                                <td class="text-end">₦@CompletedSale.ShippingAmount.ToString("N2")</td>
                                            </tr>
                                        }
                                        <tr>
                                            <td class="fw-bold">Tax (@(CompletedSale.TaxRate * 100)%) :</td>
                                            <td class="text-end">₦@CompletedSale.TaxAmount.ToString("N2")</td>
                                        </tr>
                                        <tr>
                                            <td class="fw-bold">Total Bill :</td>
                                            <td class="text-end">₦@CompletedSale.GrandTotal.ToString("N2")</td>
                                        </tr>
                                        <tr>
                                            <td class="fw-bold">Received :</td>
                                            <td class="text-end">₦@CompletedSale.ReceivedAmount.ToString("N2")</td>
                                        </tr>
                                        <tr>
                                            <td class="fw-bold">Change :</td>
                                            <td class="text-end">₦@CompletedSale.ChangeAmount.ToString("N2")</td>
                                        </tr>
                                        <tr>
                                            <td class="fw-bold">Payment Method :</td>
                                            <td class="text-end">@CompletedSale.PaymentMethod</td>
                                        </tr>
                                    </table>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                    <div class="text-center invoice-bar">
                        <div class="border-bottom border-dashed">
                            <p>Thank you for your business!</p>
                        </div>
                        <p class="text-dark fw-bold">Transaction: @CompletedSale.TransactionId</p>
                        <p>Thank You For Shopping With Us. Please Come Again</p>
                        <button type="button" class="btn btn-md btn-primary" @onclick="PrintReceipt">Print Receipt</button>
                    </div>
                }
                else
                {
                    <p class="text-center">No receipt data available</p>
                }
            </div>
        </div>
    </div>
</div>
