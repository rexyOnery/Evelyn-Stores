@code {
    private List<CategoryDto> Categories { get; set; } = new List<CategoryDto>();
    private bool _needsCarouselInit = false;
    private List<ProductDto> Products { get; set; } = new List<ProductDto>();
    private string SelectedCategoryId { get; set; } = "all";
    private string SearchTerm { get; set; } = string.Empty;
    private ProductDto? SelectedProduct { get; set; }
    private List<CartItem> Cart { get; set; } = new List<CartItem>();
    private string OutOfProductMessage { get; set; }
    private IEnumerable<ProductDto> SearchFilteredProducts => string.IsNullOrWhiteSpace(SearchTerm)
        ? Products
        : Products.Where(p => p.Name?.Contains(SearchTerm, StringComparison.OrdinalIgnoreCase) == true);

    private CategoryDto FetchCategory(Guid id) => Categories.FirstOrDefault(c => c.Id == id)!;

    private void SelectCategory(string id)
    {
        SelectedCategoryId = id;
        // After selecting category, reinitialize carousel on next render
        _needsCarouselInit = true;
    }

    private async Task SelectProduct(ProductDto product)
    {
        // Add to cart or increase quantity
        var existing = Cart.FirstOrDefault(ci => ci.Product.Id == product.Id);
        if (product.Quantity > 0)
        {
            if (existing != null)
            {
                existing.Quantity++;
            }
            else
            {
                Cart.Add(new CartItem { Product = product, Quantity = 1 });
            }
            await SaveCartAsync();
        }
        else
        {
            OutOfProductMessage = $"The product {product.Name} is currently not available. Please place an order ):";
            await JS.InvokeVoidAsync("eval", $"var m = new bootstrap.Modal(document.getElementById('outofproduct')); m.show();");
        }
    }

    private async Task IncreaseCartItem(Guid productId)
    {
        var existing = Cart.FirstOrDefault(ci => ci.Product.Id == productId);
        if (existing != null)
        {
            existing.Quantity++;
            await SaveCartAsync();
        }
    }

    private async Task DecreaseCartItem(Guid productId)
    {
        var existing = Cart.FirstOrDefault(ci => ci.Product.Id == productId);
        if (existing == null) return;
        existing.Quantity--;
        if (existing.Quantity <= 0) Cart.Remove(existing);
        await SaveCartAsync();
    }

    private class CartItem
    {
        public ProductDto Product { get; set; } = default!;
        public int Quantity { get; set; }
    }

    private async Task SaveCartAsync()
    {
        try
        {
            var json = JsonSerializer.Serialize(Cart, new JsonSerializerOptions { PropertyNamingPolicy = JsonNamingPolicy.CamelCase });
            await JS.InvokeVoidAsync("localStorage.setItem", "evelyn_cart", json);
        }
        catch { }
    }

    private async Task LoadCartAsync()
    {
        try
        {
            var json = await JS.InvokeAsync<string>("localStorage.getItem", "evelyn_cart");
            if (!string.IsNullOrWhiteSpace(json))
            {
                var items = JsonSerializer.Deserialize<List<CartItem>>(json, new JsonSerializerOptions { PropertyNameCaseInsensitive = true });
                if (items != null) Cart = items;
            }
        }
        catch { }
    }

    private async Task ClearCart()
    {
        Cart.Clear();
        try
        {
            await JS.InvokeVoidAsync("localStorage.removeItem", "evelyn_cart");
        }
        catch { }
    }

    private void PreparePayment()
    {
        // initialize payment inputs when showing payment modal
        PayingAmount = GrandTotal;
        ReceivedAmount = GrandTotal;
    }

    private async Task OpenPaymentModal(string modalId)
    {
        // initialize values
        PayingAmount = GrandTotal;
        ReceivedAmount = GrandTotal;
        // show bootstrap modal via JS
        try
        {
            await JS.InvokeVoidAsync("eval", $"var m = new bootstrap.Modal(document.getElementById('{modalId}')); m.show();");
        }
        catch
        {
            // ignore JS errors for environments without bootstrap available
        }
    }

    // Cart totals
    private decimal CartSubtotal => Cart.Sum(i => i.Product.Price * i.Quantity);
    private decimal TaxRate => 0.0m;// 0.05m; // 5% GST as example
    private decimal TaxAmount => Math.Round(CartSubtotal * TaxRate, 2);
    private decimal ShippingAmount => 0m; // change as needed or compute from selection
    private decimal DiscountRate => 0m; // placeholder for discount logic
    private decimal DiscountAmount => Math.Round(CartSubtotal * DiscountRate, 2);
    private decimal GrandTotal => Math.Round(CartSubtotal + TaxAmount + ShippingAmount - DiscountAmount, 2);

    // payment fields
    private decimal ReceivedAmount { get; set; }
    private decimal PayingAmount { get; set; }
    private decimal ChangeAmount => Math.Round(ReceivedAmount - PayingAmount, 2);
    private string PaymentReceiver { get; set; } = string.Empty;
    private string PaymentNote { get; set; } = string.Empty;
    private bool IsSubmitting { get; set; }
    private string? SubmitError { get; set; }
    private string? LastTransactionId { get; set; }
    private CompletedSaleModel? CompletedSale { get; set; }

    private async Task RemoveCartItem(Guid productId)
    {
        var existing = Cart.FirstOrDefault(ci => ci.Product.Id == productId);
        if (existing != null)
        {
            Cart.Remove(existing);
            await SaveCartAsync();
        }
    }

    // pending removal state for confirmation modal
    private Guid? _pendingRemoveId;
    private string _pendingRemoveName = string.Empty;

    private void PrepareRemove(Guid productId, string productName)
    {
        _pendingRemoveId = productId;
        _pendingRemoveName = productName;
    }

    private async Task ConfirmRemove()
    {
        if (_pendingRemoveId.HasValue)
        {
            await RemoveCartItem(_pendingRemoveId.Value);
            _pendingRemoveId = null;
            _pendingRemoveName = string.Empty;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var respWrapper = await Http.GetFromJsonAsync<ApiResponse<List<CategoryDto>>>("/api/categories");
            var resp = respWrapper?.Data;
            if (resp != null)
            {
                Categories = resp.OrderBy(c => c.Name).ToList();
                var respProdictWrapper = await Http.GetFromJsonAsync<ApiResponse<List<ProductDto>>>("/api/products");
                Products = respProdictWrapper?.Data.ToList() ?? new List<ProductDto>();
            }
        }
        catch (Exception e)
        {
            Categories = new List<CategoryDto>();
        }
        // signal that we should initialize the carousel after render
        _needsCarouselInit = true;
        Cart = new List<CartItem>();
        await LoadCartAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_needsCarouselInit)
        {
            try
            {
                await JS.InvokeVoidAsync("initPosCategoryCarousel");
            }
            catch { }
            _needsCarouselInit = false;
            StateHasChanged();
        }
    }

    // local model to avoid adding project references in the Shop project
    public class ApiResponse<T>
    {
        public bool Success { get; set; }
        public string Message { get; set; } = string.Empty;
        public T Data { get; set; }
        public int StatusCode { get; set; }
        public List<string> Errors { get; set; } = new List<string>();
    }

    // Local DTOs for sale submission
    public class CreateSaleDto
    {
        public List<CreateSaleItemDto> Items { get; set; } = new();
        public decimal Subtotal { get; set; }
        public decimal TaxRate { get; set; }
        public decimal TaxAmount { get; set; }
        public decimal ShippingAmount { get; set; }
        public decimal DiscountAmount { get; set; }
        public decimal GrandTotal { get; set; }
        public decimal ReceivedAmount { get; set; }
        public decimal ChangeAmount { get; set; }
        public string PaymentMethod { get; set; } = string.Empty;
        public string PaymentReceiver { get; set; } = string.Empty;
        public string PaymentNote { get; set; } = string.Empty;
    }

    public class CreateSaleItemDto
    {
        public Guid ProductId { get; set; }
        public string ProductName { get; set; } = string.Empty;
        public string ProductImageUrl { get; set; } = string.Empty;
        public decimal UnitPrice { get; set; }
        public int Quantity { get; set; }
        public decimal LineTotal { get; set; }
    }

    public class SaleDto
    {
        public Guid Id { get; set; }
        public string TransactionId { get; set; } = string.Empty;
    }

    // Model for displaying completed sale receipt
    public class CompletedSaleModel
    {
        public string TransactionId { get; set; } = string.Empty;
        public DateTime CreatedAt { get; set; }
        public List<CreateSaleItemDto> Items { get; set; } = new();
        public decimal Subtotal { get; set; }
        public decimal TaxRate { get; set; }
        public decimal TaxAmount { get; set; }
        public decimal ShippingAmount { get; set; }
        public decimal DiscountAmount { get; set; }
        public decimal GrandTotal { get; set; }
        public decimal ReceivedAmount { get; set; }
        public decimal ChangeAmount { get; set; }
        public string PaymentMethod { get; set; } = string.Empty;
    }

    private async Task SubmitOrderAsync(string paymentMethod)
    {
        if (Cart.Count == 0 || IsSubmitting) return;

        IsSubmitting = true;
        SubmitError = null;

        try
        {
            var dto = new CreateSaleDto
            {
                Subtotal = CartSubtotal,
                TaxRate = TaxRate,
                TaxAmount = TaxAmount,
                ShippingAmount = ShippingAmount,
                DiscountAmount = DiscountAmount,
                GrandTotal = GrandTotal,
                ReceivedAmount = ReceivedAmount,
                ChangeAmount = ChangeAmount,
                PaymentMethod = paymentMethod,
                PaymentReceiver = PaymentReceiver,
                PaymentNote = PaymentNote,
                Items = Cart.Select(ci => new CreateSaleItemDto
                {
                    ProductId = ci.Product.Id,
                    ProductName = ci.Product.Name,
                    ProductImageUrl = ci.Product.ImageUrl ?? string.Empty,
                    UnitPrice = ci.Product.Price,
                    Quantity = ci.Quantity,
                    LineTotal = ci.Product.Price * ci.Quantity
                }).ToList()
            };

            var response = await Http.PostAsJsonAsync("/api/sales", dto);

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<ApiResponse<SaleDto>>();
                LastTransactionId = result?.Data?.TransactionId;

                // Populate CompletedSale for receipt display before clearing cart
                CompletedSale = new CompletedSaleModel
                {
                    TransactionId = LastTransactionId ?? string.Empty,
                    CreatedAt = DateTime.Now,
                    Items = dto.Items,
                    Subtotal = dto.Subtotal,
                    TaxRate = dto.TaxRate,
                    TaxAmount = dto.TaxAmount,
                    ShippingAmount = dto.ShippingAmount,
                    DiscountAmount = dto.DiscountAmount,
                    GrandTotal = dto.GrandTotal,
                    ReceivedAmount = dto.ReceivedAmount,
                    ChangeAmount = dto.ChangeAmount,
                    PaymentMethod = dto.PaymentMethod
                };

                // Clear cart after successful submission
                await ClearCart();

                // Reset payment fields
                PaymentReceiver = string.Empty;
                PaymentNote = string.Empty;
                ReceivedAmount = 0;
                PayingAmount = 0;

                // Show success (could show receipt modal instead)
                await JS.InvokeVoidAsync("alert", $"Order submitted successfully! Transaction ID: {LastTransactionId}");
            }
            else
            {
                var errorResult = await response.Content.ReadFromJsonAsync<ApiResponse<object>>();
                SubmitError = errorResult?.Message ?? "Failed to submit order";
                await JS.InvokeVoidAsync("alert", $"Error: {SubmitError}");
            }
        }
        catch (Exception ex)
        {
            SubmitError = ex.Message;
            await JS.InvokeVoidAsync("alert", $"Error: {ex.Message}");
        }
        finally
        {
            IsSubmitting = false;
        }
    }

    private async Task PrintReceipt()
    {
        try
        {
            await JS.InvokeVoidAsync("window.print");
        }
        catch { }
    }

    // Using shared CategoryDto directly; no local remapping required
}
