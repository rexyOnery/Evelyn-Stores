@page "/admin/users"
@using EvelynStores.Core.DTOs
@using EvelynStores.Core.Enums
@inject EvelynStores.Core.Services.IEvelynPhilApiHttpClient ApiClient
@inject EvelynStores.Web.Services.ToastService ToastService
@inject IJSRuntime JS

<PageTitle>Users</PageTitle>

<div class="content">
	<div class="page-header">
		<div class="add-item d-flex">
			<div class="page-title">
				<h4 class="fw-bold">Users</h4>
				<h6>Manage your users</h6>
			</div>
		</div>
		<ul class="table-top-head">
			<li>
				<button class="btn btn-link p-0" type="button" title="Refresh" @onclick="LoadUsersAsync"><i class="ti ti-refresh"></i></button>
			</li>
			<li>
				<a data-bs-toggle="tooltip" data-bs-placement="top" title="Collapse" id="collapse-header"><i class="ti ti-chevron-up"></i></a>
			</li>
		</ul>
		<div class="page-btn">
			<a href="#" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#add-user"><i class="ti ti-circle-plus me-1"></i>Add User</a>
		</div>
	</div>

	<div class="card">
		<div class="card-header d-flex align-items-center justify-content-between flex-wrap row-gap-3">
			<div class="search-set">
				<div class="search-input d-flex align-items-center">
					<span class="btn-searchset"><i class="ti ti-search fs-14 feather-search"></i></span>
					<input class="form-control ms-2" placeholder="Search by name or email" @bind="SearchTerm" @bind:event="oninput" />
				</div>
			</div>
			<div class="d-flex table-dropdown my-xl-auto right-content align-items-center flex-wrap row-gap-3">
				<div class="dropdown">
					<a href="javascript:void(0);" class="dropdown-toggle btn btn-white btn-md d-inline-flex align-items-center" data-bs-toggle="dropdown">
						@(StatusFilter switch { true => "Active", false => "Inactive", _ => "Status" })
					</a>
					<ul class="dropdown-menu dropdown-menu-end p-3">
						<li>
							<a href="javascript:void(0);" class="dropdown-item rounded-1" @onclick='() => FilterByStatus(null)'>All</a>
						</li>
						<li>
							<a href="javascript:void(0);" class="dropdown-item rounded-1" @onclick='() => FilterByStatus(true)'>Active</a>
						</li>
						<li>
							<a href="javascript:void(0);" class="dropdown-item rounded-1" @onclick='() => FilterByStatus(false)'>Inactive</a>
						</li>
					</ul>
				</div>
			</div>
		</div>
		<div class="card-body p-0">
			<div class="table-responsive">
				<table class="table datatable">
					<thead class="thead-light">
						<tr>
							<th>User Name</th>
							<th>Email</th>
							<th>Role</th>
							<th>Status</th>
							<th class="no-sort"></th>
						</tr>
					</thead>
					<tbody>
						@if (FilteredUsers == null)
						{
							<tr><td colspan="5" class="text-center p-4">Loading...</td></tr>
						}
						else if (!FilteredUsers.Any())
						{
							<tr><td colspan="5" class="text-center p-4">No users found.</td></tr>
						}
						else
						{
							@foreach (var user in FilteredUsers)
							{
								<tr>
									<td>
										<div class="d-flex align-items-center">
											<a href="javascript:void(0);" class="avatar avatar-md me-2">
												<span class="avatar-title rounded-circle bg-primary text-white">@user.Name[..1].ToUpper()</span>
											</a>
											<a href="javascript:void(0);">@user.Name</a>
										</div>
									</td>
									<td>@user.Email</td>
									<td>@GetRoleName(user.UserType)</td>
									<td>
										@if (user.Status)
										{
											<span class="d-inline-flex align-items-center p-1 pe-2 rounded-1 text-white bg-success fs-10"><i class="ti ti-point-filled me-1 fs-11"></i>Active</span>
										}
										else
										{
											<span class="d-inline-flex align-items-center p-1 pe-2 rounded-1 text-white bg-danger fs-10"><i class="ti ti-point-filled me-1 fs-11"></i>Inactive</span>
										}
									</td>
									<td class="action-table-data">
										<div class="edit-delete-action">
											<a class="me-2 p-2 mb-0" href="javascript:void(0);" @onclick="() => OpenEditModal(user)">
												<i class="ti ti-edit fs-16"></i>
											</a>
											<a class="p-2 mb-0" href="javascript:void(0);" @onclick="() => ConfirmDelete(user.Id)" @onclick:preventDefault="true">
												<i class="ti ti-trash fs-16"></i>
											</a>
										</div>
									</td>
								</tr>
							}
						}
					</tbody>
				</table>
			</div>
		</div>
	</div>
</div>

<!-- Add User Modal -->
<div class="modal fade" id="add-user">
	<div class="modal-dialog modal-dialog-centered">
		<div class="modal-content">
			<div class="page-wrapper-new p-0">
				<div class="content">
					<div class="modal-header">
						<div class="page-title">
							<h4>Add User</h4>
						</div>
						<button type="button" class="close" data-bs-dismiss="modal" aria-label="Close">
							<span aria-hidden="true">&times;</span>
						</button>
					</div>
					<EditForm Model="NewUser" OnValidSubmit="CreateUserAsync" FormName="addUser">
						<DataAnnotationsValidator />
						<div class="modal-body">
							<div class="row">
								<div class="col-lg-12">
									<div class="mb-3">
										<label class="form-label">User Name<span class="text-danger ms-1">*</span></label>
										<InputText class="form-control" @bind-Value="NewUser.Name" />
										<ValidationMessage For="() => NewUser.Name" />
									</div>
								</div>
								<div class="col-lg-12">
									<div class="mb-3">
										<label class="form-label">Role<span class="text-danger ms-1">*</span></label>
										<InputSelect class="form-select" @bind-Value="NewUser.UserType">
											<option value="0">Select User Role</option>
											<option value="1">Admin</option>
											<option value="2">Sales Person</option>
										</InputSelect>
									</div>
								</div>
								<div class="col-lg-12">
									<div class="mb-3">
										<label class="form-label">Email<span class="text-danger ms-1">*</span></label>
										<InputText class="form-control" @bind-Value="NewUser.Email" />
										<ValidationMessage For="() => NewUser.Email" />
									</div>
								</div>
								<div class="col-lg-6">
									<div class="mb-3">
										<label class="form-label">Password<span class="text-danger ms-1">*</span></label>
										<InputText type="password" class="form-control" @bind-Value="NewUser.Password" />
										<ValidationMessage For="() => NewUser.Password" />
									</div>
								</div>
								<div class="col-lg-6">
									<div class="mb-3">
										<label class="form-label">Confirm Password<span class="text-danger ms-1">*</span></label>
										<InputText type="password" class="form-control" @bind-Value="NewUser.ConfirmPassword" />
										<ValidationMessage For="() => NewUser.ConfirmPassword" />
									</div>
								</div>
							</div>
						</div>
						<div class="modal-footer">
							<button type="button" class="btn me-2 btn-secondary" data-bs-dismiss="modal">Cancel</button>
							<button type="submit" class="btn btn-primary" disabled="@IsSubmitting">@(IsSubmitting ? "Adding..." : "Add User")</button>
						</div>
					</EditForm>
				</div>
			</div>
		</div>
	</div>
</div>

<!-- Edit User Modal -->
<div class="modal fade" id="edit-user">
	<div class="modal-dialog modal-dialog-centered">
		<div class="modal-content">
			<div class="page-wrapper-new p-0">
				<div class="content">
					<div class="modal-header">
						<div class="page-title">
							<h4>Edit User</h4>
						</div>
						<button type="button" class="close" data-bs-dismiss="modal" aria-label="Close">
							<span aria-hidden="true">&times;</span>
						</button>
					</div>
					<EditForm Model="EditUserModel" OnValidSubmit="UpdateUserAsync" FormName="editUser">
						<DataAnnotationsValidator />
						<div class="modal-body">
							<div class="row">
								<div class="col-lg-12">
									<div class="mb-3">
										<label class="form-label">User Name<span class="text-danger ms-1">*</span></label>
										<InputText class="form-control" @bind-Value="EditUserModel.Name" />
										<ValidationMessage For="() => EditUserModel.Name" />
									</div>
								</div>
								<div class="col-lg-12">
									<div class="mb-3">
										<label class="form-label">Role<span class="text-danger ms-1">*</span></label>
										<InputSelect class="form-select" @bind-Value="EditUserModel.UserType">
											<option value="1">Admin</option>
											<option value="2">Sales Person</option>
										</InputSelect>
									</div>
								</div>
								<div class="col-lg-12">
									<div class="mb-3">
										<label class="form-label">Email<span class="text-danger ms-1">*</span></label>
										<InputText class="form-control" @bind-Value="EditUserModel.Email" />
										<ValidationMessage For="() => EditUserModel.Email" />
									</div>
								</div>
								<div class="col-lg-12">
									<div class="status-toggle modal-status d-flex justify-content-between align-items-center">
										<span class="status-label">Status</span>
										<InputCheckbox id="edit-status" class="check" @bind-Value="EditUserModel.Status" />
										<label for="edit-status" class="checktoggle"></label>
									</div>
								</div>
							</div>
						</div>
						<div class="modal-footer">
							<button type="button" class="btn me-2 btn-secondary" data-bs-dismiss="modal">Cancel</button>
							<button type="submit" class="btn btn-primary" disabled="@IsSubmitting">@(IsSubmitting ? "Saving..." : "Save Changes")</button>
						</div>
					</EditForm>
				</div>
			</div>
		</div>
	</div>
</div>

<DeleteModal Entity="User" EntityId="SelectedDeleteId" OnConfirm="DeleteUserAsync" />

@code {
	private List<UserDto>? AllUsers;
	private bool? StatusFilter;
	private Guid? SelectedDeleteId;
	private bool IsSubmitting;

	private RegisterDto NewUser { get; set; } = new() { UserType = 0 };
	private UserDto EditUserModel { get; set; } = new();

	private string _searchTerm = string.Empty;
	private string SearchTerm
	{
		get => _searchTerm;
		set { _searchTerm = value; }
	}

	private IEnumerable<UserDto>? FilteredUsers
	{
		get
		{
			if (AllUsers is null) return null;
			IEnumerable<UserDto> q = AllUsers;

			if (StatusFilter.HasValue)
				q = q.Where(u => u.Status == StatusFilter.Value);

			if (!string.IsNullOrWhiteSpace(SearchTerm))
			{
				var s = SearchTerm.Trim();
				q = q.Where(u =>
					u.Name.Contains(s, StringComparison.OrdinalIgnoreCase) ||
					u.Email.Contains(s, StringComparison.OrdinalIgnoreCase));
			}

			return q;
		}
	}

	protected override async Task OnInitializedAsync()
	{
		await LoadUsersAsync();
	}

	private async Task LoadUsersAsync()
	{
		AllUsers = null;
		try
		{
			var resp = await ApiClient.GetAsync<List<UserDto>>("/api/users");
			AllUsers = resp?.Data ?? [];
		}
		catch
		{
			AllUsers = [];
			ToastService.ShowError("Failed to load users");
		}
	}

	private async Task CreateUserAsync()
	{
		IsSubmitting = true;
		try
		{
			var resp = await ApiClient.PostAsync<object>("/api/users", NewUser);
			if (resp.Success)
			{
				ToastService.ShowSuccess("User created");
				NewUser = new RegisterDto { UserType = 0 };
				await HideModal("#add-user");
				await LoadUsersAsync();
			}
			else
			{
				ToastService.ShowError(resp.Message ?? "Failed to create user");
			}
		}
		catch (Exception ex)
		{
			ToastService.ShowError("Error: " + ex.Message);
		}
		finally
		{
			IsSubmitting = false;
		}
	}

	private async Task OpenEditModal(UserDto user)
	{
		EditUserModel = new UserDto
		{
			Id = user.Id,
			Name = user.Name,
			Email = user.Email,
			UserType = user.UserType,
			Status = user.Status,
			CreatedAt = user.CreatedAt
		};
		await ShowModal("#edit-user");
	}

	private async Task UpdateUserAsync()
	{
		IsSubmitting = true;
		try
		{
			var resp = await ApiClient.PutAsync<UserDto>($"/api/users/{EditUserModel.Id}", EditUserModel);
			if (resp.Success)
			{
				ToastService.ShowSuccess("User updated");
				await HideModal("#edit-user");
				await LoadUsersAsync();
			}
			else
			{
				ToastService.ShowError(resp.Message ?? "Failed to update user");
			}
		}
		catch (Exception ex)
		{
			ToastService.ShowError("Error: " + ex.Message);
		}
		finally
		{
			IsSubmitting = false;
		}
	}

	private void ConfirmDelete(Guid id)
	{
		SelectedDeleteId = id;
		_ = ShowModal("#delete-modal");
	}

	private async Task DeleteUserAsync(Guid id)
	{
		try
		{
			var resp = await ApiClient.DeleteAsync($"/api/users/{id}");
			if (resp.Success)
			{
				ToastService.ShowSuccess("User deleted");
				await LoadUsersAsync();
			}
			else
			{
				ToastService.ShowError(resp.Message ?? "Failed to delete user");
			}
		}
		catch (Exception ex)
		{
			ToastService.ShowError("Error: " + ex.Message);
		}
	}

	private void FilterByStatus(bool? status)
	{
		StatusFilter = status;
	}

	private static string GetRoleName(int userType) => userType switch
	{
		(int)UserType.Admin => "Admin",
		(int)UserType.Sales => "Sales Person",
		_ => "Unknown"
	};

	private async Task ShowModal(string selector)
	{
		try { await JS.InvokeVoidAsync("eval", $"$('{selector}').modal('show');"); } catch { }
	}

	private async Task HideModal(string selector)
	{
		try { await JS.InvokeVoidAsync("eval", $"$('{selector}').modal('hide');"); } catch { }
	}
}
